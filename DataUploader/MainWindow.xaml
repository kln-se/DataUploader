<Window x:Name="mW" x:Class="DataUploader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DataUploader"
        mc:Ignorable="d"
        Title="DataUploader 1.0" Height="450" Width="440" MinWidth="440" MinHeight="450" HorizontalAlignment="Left" VerticalAlignment="Top">
    <Grid>
        <TabControl>
            <TabItem Header="Импорт данных">
                <Grid>
                    <ListBox x:Name="lbFolderContent" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="24,295,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Height="100"/>
                    <Button x:Name="btnBrowseFile" Content="Обзор..." HorizontalAlignment="Left" Margin="310,40,0,0" VerticalAlignment="Top" Click="ChooseFileDialog" RenderTransformOrigin="0.371,-0.349" Width="90" Height="20" MinWidth="90"/>
                    <Button x:Name="btnBrowseDestination" Content="Обзор..." HorizontalAlignment="Left" Margin="276,137,0,0" VerticalAlignment="Top" Width="90" Height="20" Click="ChooseFolderDialog"/>
                    <TextBox x:Name="tbFilePath" HorizontalAlignment="Left" Margin="20,40,0,0" TextWrapping="NoWrap" Text="Файл не выбран" VerticalAlignment="Top" Width="280" Height="20" MaxLines="1"/>
                    <TextBlock HorizontalAlignment="Left" Margin="20,20,0,0" TextWrapping="Wrap" Text="Выберете файл:" VerticalAlignment="Top" FontWeight="Normal"/>
                    <TextBox x:Name="tbDestinationPath" HorizontalAlignment="Left" Margin="20,137,0,0" TextWrapping="NoWrap" Text="..." VerticalAlignment="Top" Width="246" Height="20" MaxLines="1"/>
                    <TextBlock HorizontalAlignment="Left" Margin="20,117,0,0" TextWrapping="Wrap" VerticalAlignment="Top" FontWeight="Normal" Visibility="Visible"><Run Text="Выберете директорию"/><Run Text=" дл"/><Run Language="ru-ru" Text="я извлечения архива"/><Run Text=":"/></TextBlock>
                    <TextBox x:Name="tbTest" HorizontalAlignment="Left" Margin="169,295,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="165" Height="31"/>
                    <Rectangle HorizontalAlignment="Left" Height="33" Margin="20,75,0,0" Stroke="#FFABADB3" VerticalAlignment="Top" Width="380"/>
                    <TextBox HorizontalAlignment="Left" Margin="28,65,0,0" TextWrapping="Wrap" Text="Формат файла" VerticalAlignment="Top" Width="90" TextAlignment="Center" BorderBrush="{x:Null}"/>
                    <RadioButton x:Name="rbArchiveZip" Content="*.zip" HorizontalAlignment="Left" Margin="40,85,0,0" VerticalAlignment="Top" GroupName="fileFormat" Checked="CheckRbArchiveZip"/>
                    <RadioButton x:Name="rbDtl" Content="*.dtl" HorizontalAlignment="Left" Margin="185,85,0,0" VerticalAlignment="Top" GroupName="fileFormat" Checked="CheckRbDtl" />
                    <RadioButton x:Name="rbXls" Content="*.xls" HorizontalAlignment="Left" Margin="261,85,0,0" VerticalAlignment="Top" GroupName="fileFormat" Checked="CheckRbXls"/>
                    <RadioButton x:Name="rbXlsx" Content="*.xlsx" HorizontalAlignment="Left" Margin="333,85,0,0" VerticalAlignment="Top" GroupName="fileFormat" Checked="CheckRbXlsx"/>
                    <RadioButton x:Name="rbArchive7z" Content="*.7z" HorizontalAlignment="Left" Margin="113,85,0,0" VerticalAlignment="Top" GroupName="fileFormat" Checked="CheckRbArchive7z"/>
                    <Button x:Name="btnTest" Content="Button" HorizontalAlignment="Left" Margin="339,301,0,0" VerticalAlignment="Top"/>
                    <Button x:Name="btnExtract" Margin="376,135,0,0" Width="24" HorizontalAlignment="Left" VerticalAlignment="Top" Background="{x:Null}" BorderBrush="{x:Null}" Foreground="{x:Null}" ToolTip="Извлечь" Click="ExtractArchive">
                        <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top">
                            <Image Source="/Properties/extract_archive.ico" IsEnabled="False" />
                        </StackPanel>
                    </Button>
                </Grid>
            </TabItem>
            <TabItem Header="Параметры доступа к БД" IsEnabled="False">
                <Grid/>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
